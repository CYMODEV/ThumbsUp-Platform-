    function initAudio() { if(!audioCtx) audioCtx = new AudioContext(); if(audioCtx.state==='suspended') audioCtx.resume(); }
    function playTone(freq, type, dur, vol=0.05) {
      if(!audioCtx) return;
      let osc = audioCtx.createOscillator(), gain = audioCtx.createGain();
      osc.type = type; osc.frequency.value = freq;
      gain.gain.setValueAtTime(vol, audioCtx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
      osc.connect(gain); gain.connect(audioCtx.destination);
      osc.start(); osc.stop(audioCtx.currentTime + dur);
    }
    document.body.addEventListener('click', initAudio, {once:true});

    // --- Tab Navigation ---
    const tabs = document.querySelectorAll('.nav-icon-btn[data-tab]');
    const contents = document.querySelectorAll('.tab-content');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        contents.forEach(c => c.classList.add('hidden'));
        tab.classList.add('active');
        document.getElementById(`tab-${tab.dataset.tab}`).classList.remove('hidden');
        
        // Trigger poll animation if consumer tab
        if(tab.dataset.tab === 'consumer') {
          setTimeout(() => {
            document.getElementById('pollYes').style.width = '65%';
            document.getElementById('pollNo').style.width = '35%';
          }, 100);
        }
      });
    });

    // --- Mobile View Simulator Toggle ---
    const mainEl = document.getElementById('mainContainer');
    document.getElementById('viewWeb').addEventListener('click', function() {
      this.classList.add('active'); document.getElementById('viewMobile').classList.remove('active');
      mainEl.classList.remove('is-mobile');
    });
    document.getElementById('viewMobile').addEventListener('click', function() {
      this.classList.add('active'); document.getElementById('viewWeb').classList.remove('active');
      mainEl.classList.add('is-mobile');
    });

    // Animate Polls on load
    setTimeout(() => {
      document.getElementById('pollYes').style.width = '65%';
      document.getElementById('pollNo').style.width = '35%';
    }, 500);

    // --- Ledger & Ticker System ---
    let tickerQueue = ["System initialized. Monitoring ecosystem."];
    let ledgerTable = document.getElementById('ledgerTable');
    let ledgerCount = 0;

    function nowTime() { return new Date().toTimeString().slice(0, 8); }
    function createHash() { return Array.from({length:6}, () => Math.floor(Math.random()*16).toString(16)).join(''); }

    function pushTicker(msg) {
      tickerQueue.unshift(msg); if(tickerQueue.length > 5) tickerQueue.pop();
      const html = tickerQueue.map(t => `<span class="ticker-item">${t}</span>`).join('');
      document.getElementById('tickerLog').innerHTML = html + html; 
    }

    function addLedgerEntry(badgeType, badgeText, prefix, amtStr) {
      if(ledgerCount === 0) ledgerTable.innerHTML = ''; // clear waiting msg
      const id = prefix + createHash().toUpperCase();
      const entryHtml = `
        <div class="badge ${badgeType}">${badgeText}</div>
        <div class="hash">TX-${id}</div>
        <div class="amt">${amtStr}</div>
        <div class="time">${nowTime()}</div>
      `;
      const row = document.createElement("div"); row.className = "ledger-row"; row.innerHTML = entryHtml;
      ledgerTable.prepend(row);
      ledgerCount++;
      if(ledgerTable.children.length > 15) ledgerTable.removeChild(ledgerTable.lastChild);
      pulseNetwork(); // flash background nodes
    }

    // --- Consumer Tab Logic ---
    let currentVote = null;
    window.selectVote = function(type) {
      initAudio();
      document.getElementById('btnUp').classList.remove('active');
      document.getElementById('btnDown').classList.remove('active');
      document.getElementById(`btn${type==='up'?'Up':'Down'}`).classList.add('active');
      currentVote = type;
      if(type === 'up') { playTone(523, 'sine', 0.1); setTimeout(()=>playTone(659, 'sine', 0.2), 80); }
      else { playTone(200, 'sawtooth', 0.1); }
      document.getElementById('rewardBox').style.opacity = '1';
    };

    window.submitSentiment = function() {
      if(!currentVote) return;
      document.getElementById('feedbackMsg').value = '';
      fireGesture();
      pushTicker(`User sentiment captured (${currentVote}). <strong>10 T</strong> rewarded.`);
      addLedgerEntry('green', 'LOCAL', 'VOTE-', '+10 T');
      document.getElementById('btnUp').classList.remove('active');
      document.getElementById('btnDown').classList.remove('active');
      document.getElementById('rewardBox').style.opacity = '0.5';
      currentVote = null;
    };

    window.sendTip = function(amt) {
      fireGesture(); playTone(1200, 'triangle', 0.05); setTimeout(()=>playTone(1600, 'sine', 0.1), 80);
      pushTicker(`User tipped creator <strong>${amt} T</strong> instantly.`);
      addLedgerEntry('orange', 'WEB3', 'TIP-', `-${amt} T`);
    };

    window.sendCustomTip = function() {
      const val = document.getElementById('customTip').value;
      if(val && val > 0) { sendTip(val); document.getElementById('customTip').value = ''; }
    };

    window.castGovVote = function(choice) {
      fireGesture();
      pushTicker(`Governance vote cast: <strong>${choice.toUpperCase()}</strong> on Proposal #42.`);
      addLedgerEntry('purple', 'GOV', 'POLL-', '0 T');
    };

    // --- Creator Tab Logic ---
    window.publishContent = function() {
      fireGesture();
      pushTicker(`Creator published monetized content. Smart contract locked <strong>$2.50 T</strong> price.`);
      addLedgerEntry('green', 'LOCAL', 'PUB-', '0 T (Locked)');
    }

    window.deployModule = function(type) {
      fireGesture();
      let msg = "";
      let prefix = "";
      let cost = 0;
      
      if(type === 'poll') {
        const q = document.getElementById('regPollQ').value || "New Proposal";
        const pool = document.getElementById('regPollReward').value || "100";
        msg = `Deployed Tokenized Poll: "${q}". Seeded with <strong>${pool} T</strong>.`;
        prefix = "MOD-POLL-";
        cost = pool;
        
        // Clear inputs
        document.getElementById('regPollQ').value = '';
        document.getElementById('regPollA').value = '';
        document.getElementById('regPollB').value = '';
        document.getElementById('regPollReward').value = '';
        
      } else if (type === 'sentiment') {
        const reward = document.getElementById('regSentReward').value || "10";
        msg = `Enabled Sentiment Capture. Yield set to <strong>${reward} T / user</strong>.`;
        prefix = "MOD-SENT-";
        cost = "0"; // Cost is per interaction
        
      } else if (type === 'challenge') {
        const obj = document.getElementById('regChallObj').value || "Community Challenge";
        const prize = document.getElementById('regChallPrize').value || "500";
        msg = `Launched Branded Challenge: "${obj}". Escrowed <strong>${prize} T</strong>.`;
        prefix = "MOD-CHAL-";
        cost = prize;
        
        document.getElementById('regChallObj').value = '';
      }

      pushTicker(`Creator Function Registry: ` + msg);
      addLedgerEntry('highlight', 'SMART', prefix, cost === "0" ? "Active" : `-${cost} T`);
    }

    // --- 3D Gesture animation ---
    const sphere = document.getElementById('gestureSphere');
    const container = document.getElementById('thumbTrigger');
    
    document.addEventListener('mousemove', (e) => {
      const xAxis = (window.innerWidth / 2 - e.pageX) / 40;
      const yAxis = (window.innerHeight / 2 - e.pageY) / 40;
      sphere.style.transform = `rotateY(${-xAxis}deg) rotateX(${yAxis}deg)`;
    });

    window.fireGesture = function() {
      initAudio(); playTone(523, 'sine', 0.1); setTimeout(()=>playTone(659, 'sine', 0.2), 80);
      sphere.classList.remove('pop'); void sphere.offsetWidth; sphere.classList.add('pop');
      for(let i=0; i<8; i++) {
        let p = document.createElement('div'); p.className = 'particle';
        p.innerHTML = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>`;
        p.style.setProperty('--tx', (Math.random()-0.5)*150+'px');
        p.style.setProperty('--ty', (Math.random()*-150-50)+'px');
        p.style.setProperty('--rot', (Math.random()-0.5)*180+'deg');
        p.style.animation = `fly ${Math.random()+1}s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards`;
        container.appendChild(p);
        setTimeout(()=>p.remove(), 2000);
      }
    };
    sphere.addEventListener('click', fireGesture);

    // --- Background Node Network ---
    const canvas = document.getElementById('nodeCanvas');
    const ctx = canvas.getContext('2d');
    let nodes = [];
    function resize() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    window.addEventListener('resize', resize); resize();
    
    for(let i=0; i<60; i++) nodes.push({x: Math.random()*canvas.width, y: Math.random()*canvas.height, vx: (Math.random()-0.5)*0.3, vy: (Math.random()-0.5)*0.3, flash:0});
    
    function draw() {
      ctx.clearRect(0,0,canvas.width,canvas.height);
      nodes.forEach((n, i) => {
        n.x += n.vx; n.y += n.vy;
        if(n.x < 0 || n.x > canvas.width) n.vx *= -1;
        if(n.y < 0 || n.y > canvas.height) n.vy *= -1;
        if(n.flash > 0) n.flash -= 0.02;

        ctx.beginPath(); ctx.arc(n.x, n.y, 1.5 + (n.flash*3), 0, Math.PI*2);
        ctx.fillStyle = n.flash > 0 ? `rgba(56, 189, 248, ${Math.max(n.flash, 0.3)})` : 'rgba(148, 163, 184, 0.15)'; 
        ctx.fill();

        for(let j=i+1; j<nodes.length; j++) {
          let d = Math.hypot(n.x-nodes[j].x, n.y-nodes[j].y);
          if(d < 100) {
            ctx.beginPath(); ctx.moveTo(n.x, n.y); ctx.lineTo(nodes[j].x, nodes[j].y);
            ctx.strokeStyle = `rgba(148, 163, 184, ${0.1 * (1 - d/100)})`; ctx.stroke();
          }
        }
      });
      requestAnimationFrame(draw);
    }
    draw();

    window.pulseNetwork = function() {
      for(let i=0; i<3; i++) { nodes[Math.floor(Math.random()*nodes.length)].flash = 1; }
    };

    // --- Simulate Background Network Traffic ---
    setInterval(() => {
        if (Math.random() > 0.4) {
            const acts = [
              {msg: "voted in governance", type: "purple", txt: "NET", pre: "POLL-", amt: "0 T"},
              {msg: "tipped creator", type: "orange", txt: "NET", pre: "TIP-", amt: "-"+(Math.floor(Math.random()*10)+1)+" T"},
              {msg: "published content", type: "green", txt: "NET", pre: "PUB-", amt: "0 T"},
              {msg: "earned challenge reward", type: "green", txt: "NET", pre: "RWND-", amt: "+500 T"}
            ];
            const a = acts[Math.floor(Math.random()*acts.length)];
            pushTicker(`Network Node ${createHash().substring(0,4)} ${a.msg}.`);
            addLedgerEntry(a.type, a.txt, a.pre, a.amt);
        }
    }, 3500);

    // --- NEW ePurse Logic ---
    let walletFiat = 0.00;
    let walletTokens = 0;
    let activeIssuedCode = null;
    let activeIssuedAmt = 0;
    let activeThumbMode = 'standard';
    let currentDeliveryMode = 'standard';
    let isStaking = false;
    let stakingInterval;

    window.setDeliveryMode = function(mode) {
      currentDeliveryMode = mode;
      document.querySelectorAll('.delivery-btn').forEach(btn => {
        btn.classList.remove('active');
        if(btn.dataset.mode === mode) btn.classList.add('active');
      });
    };

    function renderFauxQR(codeStr) {
      const matrix = document.getElementById('qrMatrix');
      matrix.innerHTML = "";
      for (let i = 0; i < 25; i++) {
        const cell = document.createElement("div"); cell.className = "qr-cell";
        const charCode = codeStr.charCodeAt(i % codeStr.length);
        if ((charCode * (i+1)) % 2 === 0 || i === 0 || i === 4 || i === 20 || i === 24) cell.classList.add("active");
        matrix.appendChild(cell);
      }
    }

    window.issueCode = function() {
      const amt = parseFloat(document.getElementById('issueAmount').value);
      const partner = document.getElementById('issuePartner').value;
      if(!amt || amt <= 0) return;
      
      activeIssuedCode = Array.from({length:8}, () => "ABCDEFGHJKLMNPQRSTUVWXYZ23456789"[Math.floor(Math.random()*32)]).join('');
      activeIssuedAmt = amt;
      activeThumbMode = currentDeliveryMode;
      
      document.getElementById('theCodeValue').textContent = activeIssuedCode;
      
      const display = document.getElementById('issuedCodeDisplay');
      display.className = 'thumbcode-display'; // reset styles
      display.classList.remove('hidden');

      if(activeThumbMode === 'bearer') {
          display.classList.add('bearer-mode');
          document.getElementById('assetTypeBadge').outerHTML = `<span id="assetTypeBadge" class="badge orange">Bearer Note</span> <span class="bearer-badge">SECURE</span>`;
          document.getElementById('cryptoSignature').style.display = 'block';
          document.getElementById('cryptoSignature').textContent = "SIG: 0x" + createHash() + createHash() + "..." + createHash();
          document.getElementById('assetMeta').innerHTML = `<small style="color:rgba(251, 191, 36, 0.8); font-size:10px; font-weight:600; display:block;">Hold offline. Bearer owns value.</small>`;
          document.getElementById('copyBtn').textContent = "Save";
          pushTicker(`Merchant printed Offline Bearer Instrument for <strong>$${amt.toFixed(2)}</strong>.`);
          addLedgerEntry('orange', 'LOCAL', 'PRNT-', `$${amt.toFixed(2)}`);
          
          // Print sound effect
          initAudio(); 
          playTone(100, 'square', 0.05); 
          setTimeout(()=>playTone(150, 'square', 0.05), 80); 
          setTimeout(()=>playTone(80, 'sawtooth', 0.1), 160);
      } else if (activeThumbMode === 'web3') {
          document.getElementById('assetTypeBadge').outerHTML = `<span id="assetTypeBadge" class="badge highlight">Tokenized</span> <span class="token-badge">WEB3</span>`;
          document.getElementById('cryptoSignature').style.display = 'none';
          document.getElementById('assetMeta').innerHTML = `<small style="color:var(--highlight); font-size:10px; font-weight:600; display:block;">TTL: 90s · On-chain Asset</small>`;
          document.getElementById('copyBtn').textContent = "Copy";
          pushTicker(`Merchant minted Web3 Token for <strong>$${amt.toFixed(2)}</strong> via ${partner}.`);
          addLedgerEntry('highlight', 'WEB3', 'MINT-', `$${amt.toFixed(2)}`);
          fireGesture();
      } else {
          document.getElementById('assetTypeBadge').outerHTML = `<span id="assetTypeBadge" class="badge green">Standard Asset</span>`;
          document.getElementById('cryptoSignature').style.display = 'none';
          document.getElementById('assetMeta').innerHTML = `<small style="color:var(--accent); font-size:10px; font-weight:600; display:block;">TTL: 90s · Single use</small>`;
          document.getElementById('copyBtn').textContent = "Copy";
          pushTicker(`Merchant issued Standard Asset for <strong>$${amt.toFixed(2)}</strong> via ${partner}.`);
          addLedgerEntry('green', 'LOCAL', 'ISSU-', `$${amt.toFixed(2)}`);
          fireGesture();
      }

      renderFauxQR(activeIssuedCode);
    }

    window.copyThumbCode = function() {
      if(!activeIssuedCode) return;
      navigator.clipboard.writeText(activeIssuedCode).catch(()=>{});
      
      const btn = document.getElementById('copyBtn');
      const ogText = btn.textContent;
      btn.textContent = activeThumbMode === 'bearer' ? "Saved!" : "Copied!";
      setTimeout(() => { btn.textContent = ogText; }, 2000);
      
      pushTicker(`Asset Code exported locally.`);
    }

    window.simulateScan = function() {
        const wrap = document.getElementById('scannerWrap');
        wrap.classList.remove('scanning'); void wrap.offsetWidth; wrap.classList.add('scanning');
        initAudio(); playTone(1200, 'square', 0.05, 0.02);
        
        setTimeout(() => {
            wrap.classList.remove('scanning');
            if (activeIssuedCode) {
                document.getElementById('claimCodeInput').value = activeIssuedCode;
                pushTicker(`Simulated Camera/QR Scan interpreted code: ${activeIssuedCode}`);
                setTimeout(claimCode, 200);
            } else {
                playTone(200, 'sawtooth', 0.2);
                pushTicker(`Scan failed: No valid code in view.`);
            }
        }, 600);
    }

    function updateEpurseUI() {
      document.getElementById('walletBal').textContent = "$" + walletFiat.toFixed(2);
      document.getElementById('tokenBal').textContent = Math.floor(walletTokens) + " $THUMB";
      
      const tier = document.getElementById('epurseTier');
      tier.className = "tier-badge";
      if(walletTokens >= 200) { tier.classList.add('tier-gold'); tier.textContent = 'GOLD'; }
      else if(walletTokens >= 50) { tier.classList.add('tier-silver'); tier.textContent = 'SILVER'; }
      else { tier.classList.add('tier-bronze'); tier.textContent = 'BRONZE'; }
    }

    window.claimCode = function() {
      const input = document.getElementById('claimCodeInput').value.trim().toUpperCase();
      if(!input) return;
      
      if(input === activeIssuedCode) {
        walletFiat += activeIssuedAmt;
        
        let claimPrefix = 'CLAM-';
        let badgeColor = 'green';
        let badgeTxt = 'LOCAL';
        let actionMsg = 'claimed Asset';
        
        if (activeThumbMode === 'bearer') {
            claimPrefix = 'RDEM-'; badgeColor = 'orange'; badgeTxt = 'LOCAL'; actionMsg = 'redeemed Bearer Instrument';
        } else if (activeThumbMode === 'web3') {
            claimPrefix = 'BURN-'; badgeColor = 'highlight'; badgeTxt = 'WEB3'; actionMsg = 'claimed Token';
            walletTokens += (activeIssuedAmt * 10); // arbitrary conversion for web3 bonus demo
        }

        fireGesture();
        pushTicker(`ePurse successfully ${actionMsg} <strong>${input}</strong>.`);
        addLedgerEntry(badgeColor, badgeTxt, claimPrefix, `+$${activeIssuedAmt.toFixed(2)}`);
        
        activeIssuedCode = null;
        activeIssuedAmt = 0;
        document.getElementById('issuedCodeDisplay').classList.add('hidden');
        document.getElementById('claimCodeInput').value = '';
        
        const card = document.getElementById('epurseCard');
        card.classList.remove('pulse-glow'); void card.offsetWidth; card.classList.add('pulse-glow');
        setTimeout(()=>card.classList.remove('pulse-glow'), 500);
        
        updateEpurseUI();
      } else {
        initAudio(); playTone(200, 'sawtooth', 0.2);
        pushTicker(`Failed claim: Code ${input} invalid or already used.`);
      }
    }

    window.triggerNFC = function() {
        if (walletFiat < 1.0) { 
            initAudio(); playTone(200, 'sawtooth', 0.2); 
            pushTicker(`NFC Tap failed: Insufficient fiat liquidity.`);
            return; 
        }
        const modal = document.getElementById('nfcModal');
        modal.style.display = 'flex'; void modal.offsetWidth; modal.classList.add('active');
        
        initAudio();
        playTone(100, 'square', 0.05); setTimeout(()=>playTone(150, 'square', 0.05), 80);
        
        setTimeout(() => {
            playTone(523, 'sine', 0.1); setTimeout(()=>playTone(659, 'sine', 0.2), 80);
            modal.classList.remove('active'); setTimeout(() => modal.style.display = 'none', 300);
            
            const spendAmt = Math.min(walletFiat, (Math.random() * 8 + 2)); 
            walletFiat -= spendAmt;
            updateEpurseUI();
            
            pushTicker(`ePurse paid <strong>$${spendAmt.toFixed(2)}</strong> via NFC Tap-to-Pay.`);
            addLedgerEntry('highlight', 'POS', 'SPND-', `-$${spendAmt.toFixed(2)}`);
            fireGesture();
        }, 1500);
    }

    window.triggerP2P = function() {
        if (walletTokens < 5.0) {
            initAudio(); playTone(200, 'sawtooth', 0.2); 
            pushTicker(`P2P Zap failed: Insufficient $THUMB token liquidity.`);
            return;
        }
        const sendAmt = Math.min(walletTokens, Math.floor(Math.random() * 15 + 5));
        walletTokens -= sendAmt;
        updateEpurseUI();
        
        initAudio(); playTone(1200, 'triangle', 0.05); setTimeout(()=>playTone(1600, 'sine', 0.1), 80);
        
        const recipient = "eP-" + createHash().substring(0,4).toUpperCase();
        pushTicker(`ePurse zapped <strong>${sendAmt} T</strong> to peer ${recipient}.`);
        addLedgerEntry('orange', 'P2P', 'ZAP-', `-${sendAmt} T`);
        fireGesture();
    }

    window.toggleStaking = function(el) {
      isStaking = el.checked;
      if(isStaking) {
        pushTicker(`ePurse Staking Activated (14% APY).`);
        stakingInterval = setInterval(() => {
          if(walletTokens > 0) {
            const yieldAmt = walletTokens * 0.01;
            walletTokens += yieldAmt;
            updateEpurseUI();
            
            const anchor = document.getElementById('yieldAnchor');
            const floater = document.createElement('div');
            floater.className = 'yield-float';
            floater.textContent = '+' + yieldAmt.toFixed(2);
            anchor.appendChild(floater);
            setTimeout(()=>floater.remove(), 1500);
          }
        }, 3000);
      } else {
        clearInterval(stakingInterval);
        pushTicker(`ePurse Staking Deactivated.`);
      }
    }

    // --- NEW Registries Logic ---
    window.regUser = function() {
      const alias = document.getElementById('regUserAlias').value || "Anonymous";
      const out = document.getElementById('outUser');
      fireGesture();
      out.innerHTML = `<strong>DID:</strong> did:thumb:user:${createHash()}${createHash()}<br/><strong>Alias:</strong> ${alias}<br/><strong>Status:</strong> Active`;
      out.classList.add('active');
      pushTicker(`New User DID Provisioned: ${alias}.`);
      addLedgerEntry('purple', 'REG', 'DID-', '0 T');
    }

    window.regPartner = function() {
      const brand = document.getElementById('regBrand').value || "New Brand";
      const sector = document.getElementById('regSector').value;
      const out = document.getElementById('outPartner');
      fireGesture();
      out.innerHTML = `<strong>NODE_ID:</strong> nd_${createHash()}${createHash()}<br/><strong>Brand:</strong> ${brand}<br/><strong>Sector:</strong> ${sector}<br/><strong>Status:</strong> Syncing`;
      out.classList.add('active');
      pushTicker(`Partner Registry: ${brand} deployed validator node.`);
      addLedgerEntry('warning', 'REG', 'NODE-', '0 T');
    }

    window.regDev = function() {
      const app = document.getElementById('regApp').value || "Test App";
      const out = document.getElementById('outDev');
      fireGesture();
      out.innerHTML = `<strong>API_KEY:</strong> pk_test_${createHash()}${createHash()}<br/><strong>SEC_KEY:</strong> sk_test_${createHash()}${createHash()}<br/><strong>Status:</strong> Sandbox Ready`;
      out.classList.add('active');
      pushTicker(`Dev Portal: App '${app}' generated API keys.`);
      addLedgerEntry('highlight', 'REG', 'KEY-', '0 T');
    }

    window.downloadSDK = function(platform) {
      const out = document.getElementById('sdkLog');
      initAudio(); playTone(1200, 'square', 0.05); setTimeout(()=>playTone(1600, 'sine', 0.1), 80);
      out.innerHTML = `<strong>Simulated Download Started:</strong> thumbsup-sdk-${platform.toLowerCase().replace(/[\s/.]/g, '')}-v2.4.0.zip<br/><strong>Integrations:</strong> Tipping, Sentiment Voting, Web3 Issuance<br/><strong>Status:</strong> Ready for development`;
      out.classList.add('active');
      pushTicker(`Developer initialized <strong>${platform}</strong> SDK download package.`);
      addLedgerEntry('highlight', 'DEV', 'SDK-', '0 T');
    }

  </script>
