<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>ThumbsUp Full Platform</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    :root {
      --bg: #020617;
      --card-glass: rgba(15, 23, 42, 0.55);
      --card-border: rgba(255, 255, 255, 0.08);
      --accent: #22c55e;
      --accent-glow: rgba(34, 197, 94, 0.4);
      --text: #f8fafc;
      --muted: #94a3b8;
      --danger: #ef4444;
      --warning: #f59e0b;
      --highlight: #38bdf8;
      --surface: rgba(255, 255, 255, 0.04);
    }
    
    * { box-sizing: border-box; font-family: system-ui, -apple-system, sans-serif; }
    
    body {
      margin: 0; background-color: var(--bg); color: var(--text);
      min-height: 100vh; display: flex; flex-direction: column;
      overflow-x: hidden; position: relative;
    }

    /* Animated Background */
    .bg-orb {
      position: fixed; border-radius: 50%; filter: blur(120px);
      z-index: -1; opacity: 0.35; animation: drift 20s ease-in-out infinite alternate;
      pointer-events: none;
    }
    .orb-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: #064e3b; }
    .orb-2 { bottom: -20%; right: -10%; width: 60vw; height: 60vw; background: #1e1b4b; animation-delay: -5s; }
    .orb-3 { top: 40%; left: 60%; width: 30vw; height: 30vw; background: #022c22; animation-delay: -10s; }
    @keyframes drift { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(10%, 10%) scale(1.1); } }

    /* Header */
    header {
      padding: 24px 32px; display: flex; align-items: center; justify-content: space-between;
      position: absolute; top: 0; left: 0; right: 0; z-index: 20; pointer-events: none;
    }
    header > div { pointer-events: auto; }
    header h1 { margin: 0; font-size: 22px; display: flex; align-items: center; gap: 12px; font-weight: 700; letter-spacing: -0.02em;}
    header h1 span.logo {
      width: 32px; height: 32px; border-radius: 999px;
      background: radial-gradient(circle at 30% 30%, #bbf7d0, #22c55e 40%, #16a34a 70%, #052e16 100%);
      display: inline-flex; align-items: center; justify-content: center; color: #022c22;
      box-shadow: 0 0 20px var(--accent-glow);
    }
    .tagline { font-size: 12px; color: var(--muted); margin-top: 4px; letter-spacing: 0.05em; text-transform: uppercase;}

    /* Main Layout */
    main {
      flex: 1; padding: 24px 80px 24px 20px; max-width: 1400px; width: 100%;
      margin: 80px auto 40px; perspective: 1200px; position: relative; z-index: 10;
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .grid-2 { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; }
    @media (max-width: 1024px) { .grid, .grid-2 { grid-template-columns: minmax(0, 1fr); } }

    /* Navigation */
    .floating-nav {
      position: fixed; top: 50%; right: 24px; transform: translateY(-50%);
      display: flex; flex-direction: column; gap: 16px; z-index: 50;
    }
    .nav-icon-btn {
      background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--muted); width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.3s; box-shadow: 0 8px 20px rgba(0,0,0,0.4); position: relative;
    }
    .nav-icon-btn:hover { color: var(--text); background: rgba(255, 255, 255, 0.1); transform: translateY(-2px); }
    .nav-icon-btn.active {
      color: var(--accent); background: rgba(34,197,94,0.15); border-color: rgba(34,197,94,0.4);
      box-shadow: 0 0 20px rgba(34,197,94,0.3);
    }
    .nav-icon-btn.active::after {
      content: ''; position: absolute; left: -10px; top: 50%; transform: translateY(-50%);
      width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 8px var(--accent);
    }
    .nav-divider { width: 24px; height: 1px; background: rgba(255,255,255,0.15); margin: 4px auto; }
    .icon { width: 20px; height: 20px; stroke-width: 2; stroke: currentColor; fill: none; stroke-linecap: round; stroke-linejoin: round; }

    /* Mobile Simulator View */
    main.is-mobile {
      max-width: 420px; padding: 40px 16px 24px; margin-top: 100px;
      background: rgba(2, 6, 23, 0.85); backdrop-filter: blur(20px);
      border: 8px solid #0f172a; border-radius: 40px; box-shadow: 0 40px 80px rgba(0,0,0,0.8);
    }
    main.is-mobile::before {
      content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      width: 140px; height: 28px; background: #0f172a; border-bottom-left-radius: 16px; border-bottom-right-radius: 16px;
    }
    main.is-mobile .grid, main.is-mobile .grid-2 { grid-template-columns: 1fr !important; }

    /* Cards */
    .card-wrapper { position: relative; transform-style: preserve-3d; transition: transform 0.4s; height: 100%; z-index: 1;}
    .card {
      background: var(--card-glass); backdrop-filter: blur(24px); border-radius: 24px;
      border: 1px solid var(--card-border); padding: 24px; height: 100%; display: flex; flex-direction: column;
      box-shadow: 0 24px 40px rgba(0,0,0,0.4); position: relative; overflow: hidden;
    }
    .card-glare {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 24px;
      background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.1), transparent 60%);
      opacity: 0; pointer-events: none; transition: opacity 0.3s; z-index: 10; mix-blend-mode: overlay;
    }
    .card-wrapper:hover .card-glare { opacity: 1; }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; z-index: 2; position: relative;}
    .card-title { font-size: 16px; font-weight: 600; color: #e2e8f0; display: flex; align-items: center; gap: 8px; }
    
    /* UI Elements */
    .badge { font-size: 10px; padding: 4px 10px; border-radius: 999px; background: var(--surface); border: 1px solid rgba(255,255,255,0.1); color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;}
    .badge.green { background: rgba(34,197,94,0.1); color: var(--accent); border-color: rgba(34,197,94,0.3); }
    .badge.orange { background: rgba(245,158,11,0.1); color: var(--warning); border-color: rgba(245,158,11,0.3); }
    .badge.purple { background: rgba(168,85,247,0.1); color: #c084fc; border-color: rgba(168,85,247,0.3); }

    .btn {
      border-radius: 12px; border: none; padding: 12px 20px; font-size: 14px; font-weight: 600;
      cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      transition: all 0.2s; position: relative; z-index: 2;
    }
    .btn-primary { background: linear-gradient(135deg, #4ade80, #16a34a); color: #022c22; box-shadow: 0 8px 20px rgba(34,197,94,0.3); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(34,197,94,0.4); }
    .btn-secondary { background: var(--surface); color: var(--text); border: 1px solid rgba(255,255,255,0.1); }
    .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }

    input, textarea {
      width: 100%; padding: 14px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1);
      background: rgba(0,0,0,0.3); color: var(--text); font-size: 14px; outline: none;
      transition: all 0.2s; position: relative; z-index: 2; margin-bottom: 12px;
    }
    input:focus, textarea:focus { border-color: var(--accent); background: rgba(0,0,0,0.5); box-shadow: 0 0 0 2px var(--accent-glow); }
    textarea { resize: vertical; min-height: 80px; }

    /* --- SPECIFIC MODULES --- */

    /* 1. Voting & Sentiment (IMG_2116) */
    .vote-block { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; position: relative; z-index: 2;}
    .vote-btn { background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 32px 16px; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s; color: var(--muted); }
    .vote-btn svg { width: 48px; height: 48px; transition: all 0.3s; }
    .vote-btn:hover { background: var(--surface); color: var(--text); transform: translateY(-2px); }
    .vote-btn.up.active { background: rgba(34,197,94,0.15); border-color: var(--accent); color: var(--accent); box-shadow: 0 10px 30px rgba(34,197,94,0.2); }
    .vote-btn.up.active svg { transform: scale(1.1) rotate(-10deg); filter: drop-shadow(0 0 10px var(--accent)); }
    .vote-btn.down.active { background: rgba(239,68,68,0.15); border-color: var(--danger); color: var(--danger); box-shadow: 0 10px 30px rgba(239,68,68,0.2); }
    .vote-btn.down.active svg { transform: scale(1.1) rotate(10deg); filter: drop-shadow(0 0 10px var(--danger)); }

    /* 2. Reward Box */
    .reward-box { display: flex; align-items: center; gap: 12px; background: rgba(245, 158, 11, 0.1); border: 1px dashed rgba(245, 158, 11, 0.4); padding: 12px 16px; border-radius: 12px; margin-top: 8px; position: relative; z-index: 2; }
    .reward-icon { background: var(--warning); color: #000; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-family: monospace; }
    
    /* 3. Polls & Governance (IMG_2119) */
    .poll-row { margin-bottom: 16px; position: relative; z-index: 2;}
    .poll-header { display: flex; justify-content: space-between; font-size: 13px; font-weight: 600; margin-bottom: 8px; }
    .poll-track { width: 100%; height: 40px; background: rgba(0,0,0,0.3); border-radius: 8px; overflow: hidden; position: relative; border: 1px solid rgba(255,255,255,0.05); }
    .poll-fill { height: 100%; background: linear-gradient(90deg, #ea580c, #f97316); width: 0%; transition: width 1s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; align-items: center; padding-left: 12px; color: #fff; font-weight: bold; font-size: 12px;}
    .poll-fill.winner { background: linear-gradient(90deg, #16a34a, #4ade80); }

    /* 4. Tip Jar (IMG_2119) */
    .tip-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 12px; position: relative; z-index: 2;}
    .tip-btn { background: var(--surface); border: 1px solid rgba(255,255,255,0.1); color: var(--text); border-radius: 8px; padding: 12px 0; text-align: center; font-weight: 600; font-family: monospace; cursor: pointer; transition: all 0.2s; }
    .tip-btn:hover { background: rgba(245,158,11,0.15); border-color: var(--warning); color: var(--warning); }

    /* 5. Creator Toggles (IMG_2125) */
    .creator-toggle { display: flex; justify-content: space-between; align-items: center; padding: 16px; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; margin-bottom: 12px; position: relative; z-index: 2; transition: all 0.2s; }
    .creator-toggle:hover { background: rgba(0,0,0,0.4); border-color: rgba(255,255,255,0.1); }
    .creator-toggle-label { display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 500; }
    .creator-toggle-label svg { color: var(--muted); }
    
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.1); transition: .4s; border-radius: 34px; border: 1px solid rgba(255,255,255,0.2); }
    .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: #cbd5e1; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: rgba(34,197,94,0.3); border-color: var(--accent); }
    input:checked + .slider:before { transform: translateX(20px); background-color: var(--accent); box-shadow: 0 0 10px var(--accent); }

    /* Creator Functions Registry */
    .module-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; position: relative; z-index: 2; margin-top: 16px; }
    .module-box { background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 20px; display: flex; flex-direction: column; }
    .module-box h4 { margin: 0 0 12px 0; color: var(--text); font-size: 15px; display: flex; align-items: center; gap: 8px; }
    .module-box h4 svg { color: var(--highlight); }
    .module-box .input-group { margin-bottom: 12px; }
    .module-box label { font-size: 10px; color: var(--muted); text-transform: uppercase; margin-bottom: 4px; display: block; }
    .module-box input { padding: 10px 12px; font-size: 13px; border-radius: 8px; margin-bottom: 0; }
    @media (max-width: 1024px) { .module-grid { grid-template-columns: 1fr; } }

    /* 6. Playbook Table (IMG_2219) */
    .playbook-table { width: 100%; border-collapse: collapse; font-size: 13px; position: relative; z-index: 2; background: rgba(0,0,0,0.2); border-radius: 12px; overflow: hidden; }
    .playbook-table th { background: rgba(255,255,255,0.05); color: var(--muted); text-transform: uppercase; font-size: 10px; padding: 12px 16px; text-align: left; letter-spacing: 0.05em; }
    .playbook-table td { padding: 16px; border-top: 1px solid rgba(255,255,255,0.05); vertical-align: middle; }
    .playbook-icon { width: 32px; height: 32px; background: rgba(255,255,255,0.05); border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; margin-right: 12px; color: var(--accent); float: left; }
    .reward-text { font-family: monospace; color: var(--warning); font-weight: 700; font-size: 14px; }

    /* 7. Ledger & Network */
    .ledger-table { display: flex; flex-direction: column; gap: 8px; position: relative; z-index: 2; }
    .ledger-row { display: grid; grid-template-columns: 80px 1fr 80px 80px; align-items: center; background: rgba(0,0,0,0.2); padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); font-size: 12px; animation: slideDown 0.3s forwards; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    .ledger-row .hash { font-family: ui-monospace, monospace; color: var(--highlight); }
    .ledger-row .amt { justify-self: end; font-family: monospace; font-weight: 700; color: var(--text); }
    .ledger-row .time { justify-self: end; color: var(--muted); font-size: 10px; }

    /* 8. Ecosystem Matrix (IMG_2123) */
    .matrix-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; position: relative; z-index: 2; }
    .matrix-col { background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 16px; }
    .matrix-col h4 { margin: 0 0 12px 0; color: #ea580c; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; }
    .matrix-col ul { list-style: none; padding: 0; margin: 0; font-size: 12px; color: var(--muted); }
    .matrix-col ul li { margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
    .matrix-col ul li::before { content: '•'; color: var(--accent); }

    /* Thumb Gesture 3D */
    .gesture-container { position: fixed; bottom: 40px; right: 40px; width: 70px; height: 70px; z-index: 100; perspective: 1000px; }
    .gesture-sphere {
      width: 100%; height: 100%; border-radius: 50%; background: radial-gradient(circle at 35% 35%, #86efac, #22c55e, #14532d);
      box-shadow: inset -8px -8px 16px rgba(0,0,0,0.6), inset 8px 8px 16px rgba(255,255,255,0.5), 0 10px 25px rgba(34,197,94,0.4);
      display: flex; align-items: center; justify-content: center; animation: float 4s ease-in-out infinite;
      cursor: pointer; transform-style: preserve-3d; transition: all 0.2s;
    }
    .gesture-sphere svg { color: #022c22; filter: drop-shadow(0 2px 2px rgba(255,255,255,0.4)); width: 32px; height: 32px; pointer-events: none;}
    .gesture-sphere:active { transform: scale(0.9); }
    .gesture-sphere.pop { animation: pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.3) rotate(-15deg); filter: brightness(1.3); } 100% { transform: scale(1) rotate(0); } }

    .particle { position: absolute; width: 16px; height: 16px; color: #4ade80; pointer-events: none; opacity: 0; z-index: 99;}
    @keyframes fly { 0% { opacity: 1; transform: translate(0,0) scale(0.5); } 100% { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(1.5) rotate(var(--rot)); } }

    /* Ledger Ticker */
    .network-ticker {
      position: fixed; bottom: 0; left: 0; right: 0; height: 32px; background: rgba(2, 6, 23, 0.9);
      border-top: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; padding: 0 16px; z-index: 50;
      font-family: monospace; font-size: 11px; color: var(--muted); overflow: hidden;
    }
    .ticker-content { display: flex; white-space: nowrap; animation: marquee 25s linear infinite; }
    .ticker-item { margin-right: 32px; display: inline-flex; align-items: center; gap: 8px; }
    .ticker-item strong { color: var(--highlight); }
    @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

    /* Delivery Modes & Bearer Skeumorphism */
    .delivery-options { display: flex; gap: 8px; width: 100%; background: rgba(0,0,0,0.2); padding: 4px; border-radius: 16px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 16px; position: relative; z-index: 2; }
    .delivery-btn { flex: 1; padding: 10px; border-radius: 12px; border: 1px solid transparent; background: transparent; color: var(--muted); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; transition: all 0.3s; display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .delivery-btn:hover { background: rgba(255,255,255,0.05); color: var(--text); }
    .delivery-btn.active { background: rgba(34,197,94,0.15); border-color: var(--accent); color: var(--accent); box-shadow: 0 0 15px rgba(34,197,94,0.2); }
    .delivery-btn.active[data-mode="web3"] { background: rgba(56,189,248,0.15); border-color: var(--highlight); color: var(--highlight); box-shadow: 0 0 15px rgba(56,189,248,0.2); }
    .delivery-btn.active[data-mode="bearer"] { background: rgba(251,191,36,0.15); border-color: var(--bearer); color: var(--bearer); box-shadow: 0 0 15px rgba(251,191,36,0.2); }

    .thumbcode-display { margin-top: 16px; padding: 16px; border-radius: 12px; background: linear-gradient(145deg, rgba(34,197,94,0.1), rgba(0,0,0,0.4)); border: 1px solid rgba(34,197,94,0.3); display: flex; justify-content: space-between; align-items: stretch; gap: 12px; position: relative; overflow: hidden; transition: all 0.3s; }
    .thumbcode-display span.code { font-family: ui-monospace, monospace; letter-spacing: 0.2em; font-size: 18px; font-weight: 700; color: var(--accent); }
    
    .thumbcode-display.bearer-mode { background: linear-gradient(145deg, rgba(69, 26, 3, 0.8), rgba(15, 23, 42, 0.9)); border: 1px solid rgba(251, 191, 36, 0.4); box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 0 20px rgba(251, 191, 36, 0.1); }
    .thumbcode-display.bearer-mode::after { content: 'BEARER INSTRUMENT'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%) rotate(-10deg); font-size: 28px; font-weight: 800; color: rgba(251, 191, 36, 0.05); pointer-events: none; white-space: nowrap; letter-spacing: 0.2em; }
    .thumbcode-display.bearer-mode span.code { color: var(--bearer); text-shadow: 0 0 10px rgba(251, 191, 36, 0.5); }
    .crypto-signature { font-family: ui-monospace, monospace; font-size: 8px; color: rgba(251, 191, 36, 0.6); word-break: break-all; margin-top: 6px; line-height: 1.2; max-width: 180px; }

    .qr-matrix { display: grid; grid-template-columns: repeat(5, 1fr); gap: 2px; width: 48px; height: 48px; padding: 4px; background: rgba(0,0,0,0.5); border-radius: 8px; border: 1px solid rgba(34,197,94,0.3); flex-shrink: 0; transition: all 0.5s; }
    .bearer-mode .qr-matrix { border-color: rgba(251, 191, 36, 0.4); background: rgba(69, 26, 3, 0.5); }
    .qr-cell { background: transparent; border-radius: 1px; transition: background 0.3s; }
    .qr-cell.active { background: var(--accent); box-shadow: 0 0 4px var(--accent); }
    .bearer-mode .qr-cell.active { background: var(--bearer); box-shadow: 0 0 4px var(--bearer); }
    
    .token-badge { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; padding: 2px 6px; border-radius: 4px; font-size: 9px; vertical-align: middle; margin-left: 6px; font-weight: 700; text-shadow: none; border: none;}
    .bearer-badge { background: linear-gradient(135deg, #451a03, #b45309); color: #fde68a; border: 1px solid #fbbf24; padding: 2px 6px; border-radius: 4px; font-size: 9px; vertical-align: middle; margin-left: 6px; font-weight: 700; text-shadow: none;}

    /* ePurse Liquidity Modules: NFC, P2P, Scanner */
    .scanner-line { position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--accent); box-shadow: 0 0 15px 2px var(--accent-glow); opacity: 0; pointer-events: none; z-index: 5; }
    .scanner-wrap.scanning .scanner-line { animation: scan-sweep 0.6s cubic-bezier(0.4, 0, 0.2, 1); opacity: 1; }
    @keyframes scan-sweep { 0% { top: 0; } 50% { top: 100%; } 100% { top: 0; } }

    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(2, 6, 23, 0.8); backdrop-filter: blur(8px); display: flex; justify-content: center; align-items: center; z-index: 1000; opacity: 0; transition: opacity 0.3s; pointer-events: none;}
    .modal-overlay.active { opacity: 1; pointer-events: auto;}
    .bio-modal-card { background: var(--card-glass); border: 1px solid rgba(56, 189, 248, 0.4); border-radius: 24px; padding: 32px; text-align: center; box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 20px rgba(56, 189, 248, 0.1); transform: scale(0.9); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .modal-overlay.active .bio-modal-card { transform: scale(1); }
    .nfc-ripple { position: absolute; border: 2px solid #38bdf8; border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 30px; height: 30px; animation: nfc-wave 1.5s infinite ease-out; opacity: 0; }
    @keyframes nfc-wave { 0% { width: 30px; height: 30px; opacity: 1; } 100% { width: 120px; height: 120px; opacity: 0; } }

    /* Utilities */
    .hidden { display: none !important; }
    .mt-4 { margin-top: 16px; } .mb-4 { margin-bottom: 16px; } .mb-2 { margin-bottom: 8px; }
    .text-sm { font-size: 13px; } .text-xs { font-size: 11px; } .text-muted { color: var(--muted); }

    /* --- NEW: ePurse & Registry Styles --- */
    .epurse-card { background: linear-gradient(135deg, #1e3a8a, #3b82f6, #0f172a); border-radius: 16px; padding: 20px; position: relative; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.4), inset 0 1px 1px rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); margin-top: 16px; transition: all 0.3s ease; }
    .epurse-card.pulse-glow { box-shadow: 0 0 30px rgba(59, 130, 246, 0.8), inset 0 1px 1px rgba(255,255,255,0.5); transform: scale(1.02); }
    .epurse-card::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle at center, rgba(255,255,255,0.1) 0%, transparent 60%); pointer-events: none; }
    .epurse-balance { font-size: 32px; font-weight: 700; font-family: ui-monospace, "SF Mono", monospace; color: #fff; text-shadow: 0 2px 10px rgba(59,130,246,0.5); position: relative; z-index: 2; }
    .epurse-label { font-size: 11px; text-transform: uppercase; color: #93c5fd; letter-spacing: 0.1em; margin-bottom: 4px; position: relative; z-index: 2; }
    .tier-badge { font-size: 9px; font-weight: 800; padding: 2px 6px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.1em; margin-left: 8px; vertical-align: middle; transition: all 0.5s ease; }
    .tier-bronze { background: linear-gradient(135deg, #78350f, #b45309); color: #fef3c7; border: 1px solid #d97706; }
    .tier-silver { background: linear-gradient(135deg, #475569, #94a3b8); color: #f8fafc; border: 1px solid #cbd5e1; box-shadow: 0 0 10px rgba(148,163,184,0.4); }
    .tier-gold { background: linear-gradient(135deg, #854d0e, #eab308); color: #fef08a; border: 1px solid #fde047; box-shadow: 0 0 15px rgba(234,179,8,0.6); }
    .yield-float { position: absolute; color: #4ade80; font-family: ui-monospace, monospace; font-size: 12px; font-weight: bold; pointer-events: none; animation: floatUp 1.5s ease-out forwards; z-index: 10; white-space: nowrap; }
    @keyframes floatUp { 0% { opacity: 1; transform: translateY(0) scale(1); } 100% { opacity: 0; transform: translateY(-30px) scale(1.2); } }
    
    .api-key-box { background: rgba(0,0,0,0.4); border: 1px dashed rgba(168, 85, 247, 0.4); padding: 12px; border-radius: 12px; font-family: ui-monospace, monospace; font-size: 11px; color: #d8b4fe; word-break: break-all; margin-top: 12px; display: none; animation: slideDown 0.3s ease forwards;}
    .api-key-box.active { display: block; }
    .registry-btn { background: linear-gradient(135deg, #a855f7, #7e22ce); color: #fff; box-shadow: 0 8px 20px rgba(168,85,247,0.3); border:none; }
    .registry-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 24px rgba(168,85,247,0.5); }
    
    .thumbcode-display { margin-top: 16px; padding: 16px; border-radius: 12px; background: linear-gradient(145deg, rgba(34,197,94,0.1), rgba(0,0,0,0.4)); border: 1px solid rgba(34,197,94,0.3); display: flex; justify-content: space-between; align-items: center; gap: 12px; }
    .thumbcode-display span.code { font-family: ui-monospace, monospace; letter-spacing: 0.2em; font-size: 18px; font-weight: 700; color: var(--accent); }
  </style>
</head>
<body>

  <!-- Background Layer -->
  <canvas id="nodeCanvas" style="position:fixed; top:0; left:0; width:100%; height:100%; z-index:-2; pointer-events:none;"></canvas>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>
  <div class="bg-orb orb-3"></div>

  <!-- Header -->
  <header>
    <div>
      <h1>
        <span class="logo">
          <svg class="icon" viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
        </span>
        ThumbsUp
      </h1>
      <div class="tagline">Interactive Ecosystem Platform</div>
    </div>
  </header>

  <!-- Side Navigation -->
  <nav class="floating-nav">
    <button class="nav-icon-btn active" data-tab="consumer" title="Consumer Hub (Vote, Polls, Tips)">
      <svg class="icon" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
    </button>
    <button class="nav-icon-btn" data-tab="creator" title="Creator Dashboard">
      <svg class="icon" viewBox="0 0 24 24"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
    </button>
    <button class="nav-icon-btn" data-tab="epurse" title="ePurse Wallet & Issuance">
      <svg class="icon" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
    </button>
    <button class="nav-icon-btn" data-tab="registry" title="Ecosystem Registries">
      <svg class="icon" viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
    </button>
    <button class="nav-icon-btn" data-tab="playbook" title="Playbook & Ecosystem Map">
      <svg class="icon" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
    </button>
    <button class="nav-icon-btn" data-tab="network" title="Network Ledger & Validators">
      <svg class="icon" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
    </button>
    
    <div class="nav-divider"></div>
    <button class="nav-icon-btn active" id="viewWeb" title="Web View">
      <svg class="icon" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
    </button>
    <button class="nav-icon-btn" id="viewMobile" title="Mobile Simulator">
      <svg class="icon" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>
    </button>
  </nav>

  <main id="mainContainer">

    <!-- ==========================================
         TAB 1: CONSUMER ENGAGEMENT
         ========================================== -->
    <div id="tab-consumer" class="tab-content">
      <div class="grid">
        <!-- Sentiment Capture -->
        <div class="card-wrapper">
          <div class="card">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">Sentiment Capture</div>
              <span class="badge">App View</span>
            </div>
            <h2 style="margin:0 0 16px 0; font-size:20px;">What do you think?</h2>
            <div class="vote-block">
              <div class="vote-btn up" id="btnUp" onclick="selectVote('up')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg>
              </div>
              <div class="vote-btn down" id="btnDown" onclick="selectVote('down')">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h3a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2h-3"></path></svg>
              </div>
            </div>
            <div style="position:relative; z-index:2; margin-bottom: 16px;">
              <textarea id="feedbackMsg" placeholder="Give detailed feedback..."></textarea>
              <button class="btn btn-primary" style="position:absolute; bottom:24px; right:12px; padding:6px 16px;" onclick="submitSentiment()">Submit</button>
            </div>
            <div class="reward-box" id="rewardBox" style="opacity:0.5; transition: opacity 0.3s;">
              <div class="reward-icon">T</div>
              <div>
                <div style="font-weight:700; color:var(--text); font-size:16px;">10 Thumbs</div>
                <div style="font-size:11px; color:var(--warning);">Earned on submission</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Governance Vote & Quick Polls -->
        <div class="card-wrapper">
          <div class="card">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">Governance Vote</div>
              <span class="badge green">Live</span>
            </div>
            <h2 style="margin:0 0 16px 0; font-size:18px;">Add dark mode</h2>
            <p class="text-sm text-muted mb-4">Protocol improvement proposal #42</p>
            <div class="grid-2" style="gap:12px; margin-bottom:24px; position:relative; z-index:2;">
              <button class="btn btn-secondary" onclick="castGovVote('for')">For</button>
              <button class="btn btn-secondary" onclick="castGovVote('against')">Against</button>
            </div>
            <div style="border-top: 1px solid rgba(255,255,255,0.1); margin: 24px 0; position:relative; z-index:2;"></div>
            <div class="card-header" style="margin-bottom: 12px;">
              <div class="card-title">Poll Results</div>
            </div>
            <div class="poll-row">
              <div class="poll-header"><span>Yes</span> <span>65%</span></div>
              <div class="poll-track"><div class="poll-fill winner" id="pollYes" style="width:0%">65%</div></div>
            </div>
            <div class="poll-row">
              <div class="poll-header"><span>No</span> <span>35%</span></div>
              <div class="poll-track"><div class="poll-fill" id="pollNo" style="width:0%">35%</div></div>
            </div>
          </div>
        </div>

        <!-- Tip Jar -->
        <div class="card-wrapper">
          <div class="card">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">Send a tip</div>
              <span class="badge orange">Web3</span>
            </div>
            <p class="text-sm text-muted mb-4">Support the creator instantly with a tip from your protocol wallet.</p>
            <div class="tip-grid">
              <div class="tip-btn" onclick="sendTip(1)">1 T</div>
              <div class="tip-btn" onclick="sendTip(2)">2 T</div>
              <div class="tip-btn" onclick="sendTip(5)">5 T</div>
              <div class="tip-btn" onclick="sendTip(10)">10 T</div>
            </div>
            <input type="number" id="customTip" placeholder="Custom amount" style="margin-top:8px;" />
            <button class="btn btn-primary" style="width:100%; background:linear-gradient(135deg, #f59e0b, #d97706); box-shadow:0 8px 20px rgba(245,158,11,0.3);" onclick="sendCustomTip()">
              <svg class="icon" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              Send Tip
            </button>
            <p class="text-xs text-muted mt-4 text-center">You can instantly reward the poll creator. Transactions settle on the ThumbsUp ledger.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ==========================================
         TAB 2: CREATOR DASHBOARD
         ========================================== -->
    <div id="tab-creator" class="tab-content hidden">
      <div class="grid-2">
        <!-- Creator Form -->
        <div class="card-wrapper">
          <div class="card">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">
                <svg class="icon" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                Creator Dashboard
              </div>
            </div>
            <h3 style="margin:0 0 12px 0; font-size: 16px;">What's your content about?</h3>
            <div style="position:relative; z-index:2; margin-bottom:24px;">
              <textarea placeholder="Write a description..." style="min-height: 120px;"></textarea>
            </div>
            <h3 style="margin:0 0 12px 0; font-size: 16px;">Monetization options</h3>
            <div class="creator-toggle">
              <div class="creator-toggle-label"><svg class="icon" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg> Unlock for price</div>
              <div style="display:flex; align-items:center; gap:16px;">
                <span style="font-family:monospace; font-weight:700;">$ 2.50 T</span>
                <label class="switch"><input type="checkbox" checked><span class="slider"></span></label>
              </div>
            </div>
            <div class="creator-toggle">
              <div class="creator-toggle-label"><svg class="icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg> Tip jar (Suggested: 1T, 5T, 10T)</div>
              <label class="switch"><input type="checkbox" checked><span class="slider"></span></label>
            </div>
            <div class="creator-toggle">
              <div class="creator-toggle-label"><svg class="icon" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg> NFT badge rewards</div>
              <label class="switch"><input type="checkbox"><span class="slider"></span></label>
            </div>
            <div class="creator-toggle">
              <div class="creator-toggle-label"><svg class="icon" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg> Sponsorship slot</div>
              <label class="switch"><input type="checkbox"><span class="slider"></span></label>
            </div>
          </div>
        </div>

        <!-- Analytics & Publishing -->
        <div class="card-wrapper">
          <div class="card">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">Analytics Snapshot</div>
            </div>
            <p class="text-sm text-muted">Real-time performance metrics pulled directly from the ledger ecosystem.</p>
            <div class="analytics-row" style="margin-top: 24px;">
              <div class="stat-box">
                <span class="stat-label">Engagement</span>
                <span class="stat-val up">85% <svg class="icon" style="width:14px;height:14px;" viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg></span>
              </div>
              <div class="stat-box">
                <span class="stat-label">Revenue</span>
                <span class="stat-val warn">410 T</span>
              </div>
              <div class="stat-box">
                <span class="stat-label">Top Supporter</span>
                <span class="stat-val" style="font-size:14px;">Alex <svg class="icon" style="color:#ef4444;fill:#ef4444;width:12px;height:12px;" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg></span>
              </div>
            </div>
            <div style="border-top: 1px solid rgba(255,255,255,0.1); margin: 24px 0; position:relative; z-index:2;"></div>
            
            <h3 style="margin:0 0 12px 0; font-size: 14px; position:relative; z-index:2;">Publish Content to Ledger</h3>
            <button class="btn btn-primary" style="width:100%;" onclick="publishContent()">
              <svg class="icon" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
              Publish & Monetize
            </button>
          </div>
        </div>

        <!-- NEW: Interactive Functions Registry -->
        <div class="card-wrapper" style="grid-column: 1 / -1;">
          <div class="card" style="background: linear-gradient(135deg, rgba(15,23,42,0.8), rgba(2,6,23,0.9));">
            <div class="card-glare"></div>
            <div class="card-header">
              <div class="card-title">
                <svg class="icon" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path></svg>
                Interactive Functions Registry
              </div>
              <span class="badge purple">Smart Contracts</span>
            </div>
            <p class="text-sm text-muted mb-2">Deploy engagement modules directly to the Consumer Hub. Incentivize users using your protocol balance.</p>
            
            <div class="module-grid">
              
              <!-- 1. Quick Poll Module -->
              <div class="module-box">
                <h4><svg class="icon" viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg> Tokenized Quick Poll</h4>
                <div class="input-group">
                  <label>Poll Question</label>
                  <input type="text" id="regPollQ" placeholder="e.g., Add dark mode?" />
                </div>
                <div style="display:flex; gap:8px;">
                  <div class="input-group" style="flex:1;">
                    <label>Option 1</label>
                    <input type="text" id="regPollA" placeholder="Yes" />
                  </div>
                  <div class="input-group" style="flex:1;">
                    <label>Option 2</label>
                    <input type="text" id="regPollB" placeholder="No" />
                  </div>
                </div>
                <div class="input-group">
                  <label>Bounty Pool ($THUMB)</label>
                  <input type="number" id="regPollReward" placeholder="100" />
                </div>
                <div style="margin-top:auto; padding-top:12px;">
                  <button class="btn btn-secondary" style="width:100%; border-color:var(--highlight); color:var(--highlight);" onclick="deployModule('poll')">Deploy Poll</button>
                </div>
              </div>

              <!-- 2. Sentiment Capture Module -->
              <div class="module-box">
                <h4><svg class="icon" viewBox="0 0 24 24"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path></svg> Sentiment Capture</h4>
                <p class="text-xs text-muted" style="margin-top:0; margin-bottom:16px;">Attach up/down sentiment capture to your next post and reward users for detailed feedback.</p>
                <div class="input-group">
                  <label>Reward per User ($THUMB)</label>
                  <input type="number" id="regSentReward" placeholder="10" value="10" />
                </div>
                <div class="creator-toggle" style="background:rgba(0,0,0,0.4); padding:10px 12px; margin-bottom:12px;">
                  <span class="text-xs font-weight:600;">Require written feedback</span>
                  <label class="switch"><input type="checkbox" checked><span class="slider"></span></label>
                </div>
                <div style="margin-top:auto;">
                  <button class="btn btn-secondary" style="width:100%; border-color:var(--accent); color:var(--accent);" onclick="deployModule('sentiment')">Enable Sentiment</button>
                </div>
              </div>

              <!-- 3. Branded Challenge Module -->
              <div class="module-box">
                <h4><svg class="icon" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg> Branded Challenge</h4>
                <p class="text-xs text-muted" style="margin-top:0; margin-bottom:16px;">Launch a high-performing challenge to expand your creator base.</p>
                <div class="input-group">
                  <label>Challenge Objective</label>
                  <input type="text" id="regChallObj" placeholder="e.g., Best video using product" />
                </div>
                <div class="input-group">
                  <label>Winner Prize ($THUMB)</label>
                  <input type="number" id="regChallPrize" placeholder="500" value="500" />
                </div>
                <div style="margin-top:auto; padding-top:12px;">
                  <button class="btn btn-secondary" style="width:100%; border-color:var(--warning); color:var(--warning);" onclick="deployModule('challenge')">Launch Challenge</button>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ==========================================
         TAB 3: PLAYBOOK & ECOSYSTEM
         ========================================== -->
    <div id="tab-playbook" class="tab-content hidden">
      <div class="grid-2">
        
        <!-- Ecosystem Matrix (IMG_2123) -->
